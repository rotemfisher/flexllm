# ── LangSmith tracing (optional) ──────────────────────────────────────────────
# When LANGSMITH_API_KEY is set, setup_tracing() automatically enables tracing.
# You do NOT need to set LANGCHAIN_TRACING_V2=true manually — it is set at runtime.
LANGSMITH_API_KEY=ls__your_key_here
LANGCHAIN_PROJECT=flexllm-coach-local

# ── Data paths (defaults work if project layout is unchanged) ─────────────────
DB_PATH=data/personal/running.db
QDRANT_PATH=data/qdrant_db
QDRANT_COLLECTION=coaching_books

# ── Models ────────────────────────────────────────────────────────────────────
MODEL_ID=qwen2.5:32b
EMBED_MODEL=BAAI/bge-large-en-v1.5
