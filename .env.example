# Copy this file to .env and fill in your values.
# Never commit .env — it contains secrets.

# ── Auth (REQUIRED) ───────────────────────────────────────────────────────────
# Password shown on the Chainlit login screen. Anyone with the Cloudflare URL
# must know this to access the coach.
APP_PASSWORD=replace-with-a-strong-password

# Cookie signing secret — sessions invalidate if this changes, so pin it.
# Generate with: openssl rand -hex 32
CHAINLIT_AUTH_SECRET=replace-with-output-of-openssl-rand-hex-32

# ── Cloudflare Tunnel (optional) ──────────────────────────────────────────────
# Leave blank → a random *.trycloudflare.com URL is printed to logs on startup.
# Set to a tunnel token (from Cloudflare dashboard) → persistent custom domain.
CLOUDFLARE_TUNNEL_TOKEN=

# ── LangSmith tracing (optional) ──────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=flexllm-prod
ENVIRONMENT=prod

# ── Data paths (defaults match the docker-compose volume mount) ───────────────
DB_PATH=/data/personal/running.db
QDRANT_PATH=/data/qdrant_db
QDRANT_COLLECTION=coaching_books

# ── Models ────────────────────────────────────────────────────────────────────
MODEL_ID=qwen2.5:32b
EMBED_MODEL=BAAI/bge-large-en-v1.5
# Ollama runs on the host machine. host.docker.internal works on Mac/Windows.
# On Linux with Docker, extra_hosts in docker-compose.yml maps this automatically.
OLLAMA_BASE_URL=http://host.docker.internal:11434
