# Copy this file to .env and fill in your values.
# Never commit .env — it contains secrets.

# ── LangSmith tracing (optional) ──────────────────────────────────────────────
# When LANGSMITH_API_KEY is set, tracing is enabled automatically.
# Use a separate project per deployment to keep traces isolated.
LANGSMITH_API_KEY=ls__your_key_here
LANGCHAIN_PROJECT=flexllm-prod
# Values: local | dev | staging | prod
ENVIRONMENT=prod

# ── Data paths (defaults match the docker-compose volume mount) ───────────────
DB_PATH=/data/personal/running.db
QDRANT_PATH=/data/qdrant_db
QDRANT_COLLECTION=coaching_books

# ── Models ────────────────────────────────────────────────────────────────────
MODEL_ID=qwen2.5:32b
EMBED_MODEL=BAAI/bge-large-en-v1.5
# Where Ollama is running. Use host.docker.internal when Ollama is on the host
# machine (the default). Replace with http://ollama:11434 if you run Ollama in
# Docker too.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Security (REQUIRED) ───────────────────────────────────────────────────────
# Shared secret between the WhatsApp bridge and the Python API.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=replace-with-a-strong-random-secret

# ── WhatsApp access control ───────────────────────────────────────────────────
# Comma-separated E.164 phone numbers allowed to use the bot.
# Leave blank to allow any number that reaches your WhatsApp account.
# Example: ALLOWED_NUMBERS=+1234567890,+0987654321
ALLOWED_NUMBERS=

# ── Session behaviour ─────────────────────────────────────────────────────────
# Minutes of inactivity before a conversation summary is written and the
# in-memory session is cleared. Default: 60.
SESSION_TIMEOUT_MINUTES=60

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
